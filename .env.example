# Copy to .env and fill in.

# Port the API server listens on
PORT=3000

# Path to the SQLite database file
DB_PATH=./data/orion.db

# Optional: an LLM API key used by the URL slurp to structure messy postings
# that don't expose schema.org JobPosting JSON-LD. If unset, slurp falls back
# to JSON-LD + Open Graph meta parsing only (works for most big job boards).
# ANTHROPIC_API_KEY=
